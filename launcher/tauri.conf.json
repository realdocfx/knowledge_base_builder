{
  "build": {
    "distDir": "../public",
    "devPath": "http://127.0.0.1",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "package": {
    "productName": "Launch_KBB",
    "version": "0.5.0"
  },
  "tauri": {
    "allowlist": {
      "all": false
    },
    "bundle": {
      "active": true,
      "targets": "msi",
      "identifier": "com.kbb.airgapped.launcher",
      "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"]
    },
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob:; connect-src 'self' ws://127.0.0.1:* http://127.0.0.1:*; frame-src 'self' http://127.0.0.1:*"
    },
    "windows": []
  }
}
